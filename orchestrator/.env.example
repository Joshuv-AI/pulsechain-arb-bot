# ===============================================
# pDAI Arbitrage Bot - Orchestrator
# ===============================================

# RPC & Network
RPC_PULSECHAIN=https://rpc.pulsechain.com
CHAIN_ID=369

# ===============================================
# WebSocket Settings (for fast scanning)
# ===============================================
# WebSocket RPC URL (get from PublicNode, Moralis, or run your own node)
WS_RPC_URL=wss://pulsechain-rpc.publicnode.com/ws

# Fallback polling if WS unavailable (ms)
FALLBACK_POLL_MS=3000
WS_KEEPALIVE_MS=15000

# Operator Wallet (REQUIRED)
# Your private key (with 0x prefix)
# WARNING: Keep this secret! Never commit to git!
OPERATOR_KEY=0xYOUR_PRIVATE_KEY_HERE

# FlashSwap Executor Contract (after deployment)
FLASH_SWAP_EXECUTOR=0xYourDeployedContractAddress

# ===============================================
# Token Addresses (Verified)
# ===============================================
PDAI_ADDRESS=0x6B175474E89094c44Da98b954EedEA c495271d0F
USDC_ADDRESS=0x15d38573d2feeb82e7ad5187ab8c1d52810b1f07
DAI_ADDRESS=0xefd766ccb38eaf1dfd701853bfce31359239f305
WPLS_ADDRESS=0xa1071da3ec3ded7a51a5cb4f69d3d9f5bd9001e

# ===============================================
# Pool Addresses (Verified)
# ===============================================
PDAI_USDC_POOL=0x2db5ef4e8a7dbe195defae2d9b79948096a03274
PDAI_DAI_POOL=0x1d2be6eff95ac5c380a8d6a6143b6a97dd9d8712
USDC_DAI_POOL=0x3225e3b0d3c6b97ec9848f7b40bb3030e5497709
PDAI_WPLS_POOL=0xae8429918fdbf9a5867e3243697637dc56aa76a1

# ===============================================
# DEX Addresses
# ===============================================
PULSEX_FACTORY=0x1715a3E4A142d8b698131108995174F37aEBA10D
PULSEX_ROUTER=0x165C3410fC91EF562C50559f7d2289fEbed552d9

# ===============================================
# Runtime Settings
# ===============================================
CONCURRENCY=2
MIN_PROFIT_USD=10
MAX_SLIPPAGE_BPS=200

# Scanner speed (ms) - 100ms = fast, 1000ms = slow
SCAN_INTERVAL_MS=100

# Poll interval (ms)
POLL_MS=1000

# Gas settings
GAS_PRICE_GWEI=50
GAS_USD_PRICE=0.000002

# ===============================================
# Private Relay (optional)
# ===============================================
PRIVATE_RELAY_URL=

# Redis (optional)
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=info

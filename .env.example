# ===============================================
# pDAI Arbitrage Bot - Environment Variables
# ===============================================
# Copy this to .env and fill in the values

# ===============================================
# REQUIRED - RPC Endpoints
# ===============================================
RPC_PULSECHAIN=https://rpc.pulsechain.com
CHAIN_ID=369

# Fallback RPCs (optional but recommended)
RPC_PULSECHAIN_2=https://rpc.pulsechain.com
RPC_PULSECHAIN_3=

# ===============================================
# REQUIRED - Wallet/Private Key
# ===============================================
# Your wallet private key (with 0x prefix)
# WARNING: Keep this secret! Never commit to git
OPERATOR_KEY=0xYOUR_PRIVATE_KEY_HERE

# ===============================================
# REQUIRED - Contract Addresses (VERIFY THESE)
# ===============================================
# These must be verified on scan.pulsechain.com

# pDAI Token - VERIFIED ✓
PDAI_ADDRESS=0x6B175474E89094c44Da98b954EedEA c495271d0F

# Other Tokens - VERIFIED ✓
WPLS_ADDRESS=0xa1071da3ec3ded7a51a5cb4f69d3d9f5bd9001e
USDC_ADDRESS=0x15d38573d2feeb82e7ad5187ab8c1d52810b1f07
DAI_ADDRESS=0x6B175474E89094c44Da98b954EedEA c495271d0F
USDT_ADDRESS=TBD_VERIFY
WBTC_ADDRESS=TBD_VERIFY

# DEX Factories - VERIFIED ✓
PULSEX_FACTORY=0x1715a3E4A142d8b698131108995174F37aEBA10D
PULSEX_ROUTER=0x165C3410fC91EF562C50559f7d2289fEbed552d9
EQUALIZER_FACTORY=TBD_VERIFY
EQUALIZER_ROUTER=TBD_VERIFY
IONIC_FACTORY=TBD_VERIFY
IONIC_ROUTER=TBD_VERIFY

# Pool Addresses - VERIFIED ✓
PDAI_USDC_POOL=0x2db5ef4e8a7dbe195defae2d9b79948096a03274
PDAI_DAI_POOL=0x1d2be6eff95ac5c380a8d6a6143b6a97dd9d8712
PDAI_WPLS_POOL=0xae8429918fdbf9a5867e3243697637dc56aa76a1
USDC_DAI_POOL=0x3225e3b0d3c6b97ec9848f7b40bb3030e5497709

# Flashloan Provider
# NOTE: Using PulseX flash swaps (Uniswap V2 style) - built into DEX!
FLASHLOAN_PROVIDER=pulsex  # No external provider needed

# ===============================================
# OPTIONAL - Flashbots/Private Relay
# ===============================================
# Flashbots may not work on PulseChain - verify
FLASHBOTS_RELAY_URL=https://relay.flashbots.net
PRIVATE_RELAY_URL=TBD_VERIFY

# ===============================================
# OPTIONAL - Database
# ===============================================
REDIS_URL=redis://localhost:6379
POSTGRES_URL=postgres://user:pass@localhost:5432/pdaidb

# ===============================================
# Trading Parameters (can adjust)
# ===============================================
SCAN_INTERVAL_MS=3000
MIN_PROFIT_USD=10
MAX_SLIPPAGE_BPS=200
MAX_TRADE_SIZE_USD=50000

# ===============================================
# Risk Management
# ===============================================
MAX_DAILY_LOSS_USD=1000
MAX_CONCURRENT_TRADES=3
EMERGENCY_STOP_PERCENT=20
